# CRS-Server Environment Variables
# Copy this file to .env and fill in your values

# OpenWeatherMap API key (free tier works fine)
# Get yours at: https://openweathermap.org/api
# Used to auto-fetch rainfall when user provides a city name
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Allowed origins for CORS — comma-separated
# Dev: http://localhost:3000
# Prod: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# Path to the trained model pickle file (default: crop_model.pkl)
MODEL_PATH=crop_model.pkl
